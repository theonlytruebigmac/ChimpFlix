# ChimpFlix web frontend — example env.
# Copy to web/.env.local for local development.

# Base URL of the ChimpFlix Rust backend. Next.js rewrites /api/v1/* to
# this host so the browser sees the whole app on a single origin.
#
# Local dev (cargo run -p chimpflix-server):
#   CHIMPFLIX_API_URL=http://localhost:8080
#
# Docker compose:
#   CHIMPFLIX_API_URL=http://server:8080
CHIMPFLIX_API_URL=http://localhost:8080

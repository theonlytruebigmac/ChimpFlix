# Web-only env template for local development (`npm run dev`).
#
# In docker, all env comes from the root .env.local via compose env_file —
# you do NOT need this file. This is purely for running the Next.js dev
# server outside docker, where Next.js reads `.env.local` relative to the
# web/ directory automatically.
#
# Copy to web/.env.local. See the root .env.example for the full list of
# variables the app reads (the Rust server vars only matter when you also
# run `cargo run -p chimpflix-server` locally).


# Where the Rust API is reachable from this dev server. Default 8080 if
# you `cargo run` the server on the same host.
CHIMPFLIX_API_URL=http://localhost:8080


# Branding (baked into the bundle at build time — restart `npm run dev`
# after changing).
NEXT_PUBLIC_BRAND_NAME=ChimpFlix
NEXT_PUBLIC_BRAND_NAME_UPPER=


# Set when behind a TLS-terminating proxy in your dev setup so HSTS +
# the Secure cookie behave correctly.
APP_PUBLIC_ORIGIN=

# ──────────────────────────────────────────────────────────────────────────
# ChimpFlix environment template.
#
# Copy this file to .env.local and fill in values for your deployment.
# docker-compose.yml reads .env.local for both the `server` and `web`
# containers (`env_file:` in each service block).
#
# .env.local is gitignored. .env.example IS checked in — keep it in sync
# with the actual variables the code reads, and never commit real secrets.
# ──────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════
# SECURITY — set these before exposing the app to the internet
# ══════════════════════════════════════════════════════════════════════════

# Master key for the credential vault. Encrypts third-party API tokens
# (TMDB, OpenSubtitles, Trakt, webhook secrets, SMTP password) at rest in
# the SQLite file. Without it the server boots in PLAINTEXT mode on a
# LAN; on an internet-exposed instance (APP_PUBLIC_ORIGIN=https://…)
# the server REFUSES to start without this key unless
# CHIMPFLIX_ALLOW_PLAINTEXT_VAULT=1 is also set.
#
# Format: 64 hex characters (32 bytes).
# Generate: `openssl rand -hex 32`
#            or:  `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
#
# Rotating this key invalidates every previously-encrypted secret. Plan
# a re-entry of API tokens / passwords before you rotate.
CHIMPFLIX_SECRET_KEY=

# Escape hatch for the "no plaintext vault on a public origin" check
# above. Useful for tests / CI only. Leave UNSET in any deployment that
# stores real secrets.
# CHIMPFLIX_ALLOW_PLAINTEXT_VAULT=

# Canonical user-facing origin. Required behind any reverse proxy and
# for ALL internet-facing deployments. The server uses it for:
#   * Marking the session cookie Secure + switching to the __Host- prefix
#   * Enabling HSTS in both API and HTML responses
#   * The CSRF Origin/Referer check (rejects mutating requests whose
#     Origin doesn't match this or the cors_origins allow-list)
#   * Refusing to boot in plaintext-vault mode (see above)
#
# No trailing slash. Use the exact scheme + host + port the user types.
# Example: APP_PUBLIC_ORIGIN=https://flix.example.com
APP_PUBLIC_ORIGIN=

# Comma-separated CIDR list of upstream proxies that ChimpFlix should
# trust for `X-Forwarded-For`, `X-Real-IP`, and `CF-Connecting-IP`.
# Without this, those headers are IGNORED and the recorded client IP
# falls back to the immediate peer (usually the Docker bridge), which
# also disables any `auth_bypass_cidrs` LAN automation rule that
# depends on seeing the real client address.
#
# What to put here (pick the line that matches your topology):
#
#   * Traefik on a DIFFERENT host, reaching ChimpFlix at its LAN IP:
#     the Traefik machine's IP as a /32. Example:
#         TRUSTED_PROXIES=192.168.1.10/32
#     Pair this with a host firewall on the ChimpFlix machine that
#     only allows :8080 from that same IP — otherwise anything on the
#     LAN can hit the origin and bypass Cloudflare. Example ufw rule:
#         sudo ufw allow from 192.168.1.10 to any port 8080 proto tcp
#         sudo ufw deny  in to any port 8080 proto tcp
#
#   * Traefik on the SAME host, shared Docker network:
#     the Docker bridge range. Example:
#         TRUSTED_PROXIES=172.16.0.0/12
#
#   * Direct LAN access, no reverse proxy at all: leave empty.
#
# SECURITY: Traefik must be configured to OVERWRITE (not append) the
# client-supplied X-Forwarded-For from any caller it doesn't already
# trust — otherwise this list grants the spoof surface to anyone who
# can reach Traefik. For Traefik specifically, that means setting
# `--entrypoints.<name>.forwardedHeaders.trustedIPs=<cloudflare-ranges>`
# so it only honours XFF coming from Cloudflare's edge.
TRUSTED_PROXIES=

# Server-side HMAC secret for session cookies. Auto-generated and
# persisted into the vault on first boot if unset, so most operators
# never need to set this. Pin it explicitly only when you need cookies
# to survive a wiped data directory (e.g. blue/green deploys).
#
# Format: ≥64 hex characters. Generate: `openssl rand -hex 64`
SESSION_SECRET=

# First-run setup token (BLOCK #5 in docs/PUBLIC_RELEASE_HARDENING.md).
# When set, POST /auth/setup REQUIRES an `X-Setup-Token` request header
# whose value matches this env var exactly. Closes the CSRF-bypass race
# window between server boot and the operator completing first-run
# setup — without it, anyone reachable on the network during that
# window can claim the owner account.
#
# REQUIRED when APP_PUBLIC_ORIGIN starts with https:// (the setup
# endpoint refuses to run without it on internet-facing deployments).
# Optional on LAN-only / dev deployments, but recommended everywhere.
#
# Generate: `openssl rand -hex 32`
# Send with: `curl -H "X-Setup-Token: $TOKEN" ...`
# CHIMPFLIX_SETUP_TOKEN=


# ══════════════════════════════════════════════════════════════════════════
# INTEGRATIONS — optional, enable features when present
# ══════════════════════════════════════════════════════════════════════════

# TMDB v4 "Read Access Token" (a JWT, not the v3 API key) from
# https://www.themoviedb.org/settings/api → "API Read Access Token".
# Enables trailer autoplay in hero + modal, plus initial metadata pull
# during scans. After the first boot, the token is copied into the
# encrypted vault and you can manage it from /settings/admin/server.
TMDB_READ_TOKEN=


# ══════════════════════════════════════════════════════════════════════════
# BRANDING — baked into the client bundle at build time
# ══════════════════════════════════════════════════════════════════════════

# Wordmark shown in the top nav, login page, modals, page titles, and
# "New on …" rails. Defaults to "ChimpFlix" when unset.
#
# NEXT_PUBLIC_* values are inlined into the JS bundle at `next build`
# time, NOT read at runtime. After changing this, rebuild the web
# image: `docker compose build web` (or `npm run build` locally).
NEXT_PUBLIC_BRAND_NAME=ChimpFlix

# Override for the all-caps wordmark variant. Defaults to the auto-
# uppercased brand name. Set this if you want custom casing like
# "ChimpFLIX" instead of the auto "CHIMPFLIX".
NEXT_PUBLIC_BRAND_NAME_UPPER=

# Google Cast custom receiver app ID. Leave UNSET to cast with Google's
# stock receiver (direct-play files only — HLS transcode casting will
# 401 because the stock receiver can't carry our `?ct=` token onto
# segment requests). To enable full HLS casting:
#   1. Register a "Custom Receiver" in the Google Cast SDK Developer
#      Console (one-time $5 dev fee) pointing at
#      https://<your-APP_PUBLIC_ORIGIN>/cast/receiver.html
#   2. Register your Cast device(s) for testing in the same console.
#   3. Put the issued application ID here and rebuild the web image.
# Full walkthrough: docs/cast-receiver.md
NEXT_PUBLIC_CAST_RECEIVER_APP_ID=


# ══════════════════════════════════════════════════════════════════════════
# SERVER RUNTIME — already set in docker-compose.yml; document here too
# ══════════════════════════════════════════════════════════════════════════

# Where the server stores SQLite + caches + sessions. Inside the
# container this is `/data` (volume-mounted to ./data). Setting it
# here only matters if you run the binary outside docker.
# DATA_DIR=./data

# Bind address for the API + WebSocket server.
# BIND_ADDR=0.0.0.0:8080

# tracing filter directives. `info,sqlx=warn` is a reasonable default;
# bump to `debug,chimpflix_transcoder=trace` when debugging playback.
# RUST_LOG=info,sqlx=warn,tower_http=info

# Override the ffmpeg / ffprobe binaries. Default is whatever is in
# $PATH; the docker image ships system ffmpeg with NVENC + VAAPI
# support, so leave these unset in compose deployments.
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe

# Per-session ffmpeg virtual-memory cap in MiB (RLIMIT_AS, Linux only).
# Defends against a pathological media file triggering an unbounded
# allocation that OOMs the host.
#
# DEFAULT: 0 (disabled). Why: RLIMIT_AS caps total virtual address
# space, and CUDA's cuInit() mmaps tens of GiB of unified-memory
# address range before any allocation — any non-zero cap below ~64 GiB
# reliably kills GPU-accelerated sessions with a misleading
# CUDA_ERROR_OUT_OF_MEMORY error. The same applies to VAAPI / QSV
# to a lesser degree.
#
# Set this only on CPU-only deployments: 2048 covers 4K H.264 sw
# encode with overhead; 4096 covers 4K HEVC + multi-pass loudnorm.
# GPU operators should leave it disabled and rely on Docker's
# `mem_limit:` (cgroup-based RSS cap) for the same defense.
#
# See docs/PUBLIC_RELEASE_HARDENING.md BLOCK #3.
# CHIMPFLIX_TRANSCODER_MEMORY_MB=0

# Compose-internal URL the web service uses to reach the Rust API.
# Set as a build arg in docker-compose.yml so next.config.ts's
# rewrites() can bake it in; not generally edited.
# CHIMPFLIX_API_URL=http://server:8080

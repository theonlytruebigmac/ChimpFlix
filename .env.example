# ── Required ─────────────────────────────────────────────────────────────

# Stable identifier this app presents to plex.tv during auth.
# Generate once: `node -e "console.log(crypto.randomUUID())"` and keep it.
PLEX_CLIENT_IDENTIFIER=

# Random 32+ char string used to sign cookies (any opaque secret).
# Generate: `node -e "console.log(crypto.randomBytes(32).toString('hex'))"`
SESSION_SECRET=

# ── Branding ─────────────────────────────────────────────────────────────

# User-visible product name. Used in the top nav wordmark, login screen,
# modal "Original" badge, page titles, and "New on …" rails. Falls back
# to "ChimpFlix" when unset.
#
# Use NEXT_PUBLIC_ prefix so the value is inlined into client bundles at
# build time — it's a label, not a secret. After changing this you must
# rebuild (`npm run build` or `docker compose build`) since it's baked in.
NEXT_PUBLIC_BRAND_NAME=ChimpFlix

# Optional override for the all-caps wordmark variant. Defaults to
# NEXT_PUBLIC_BRAND_NAME.toUpperCase() — set this if you want a custom
# casing (e.g. "ChimpFLIX") instead of the auto-uppercased default.
NEXT_PUBLIC_BRAND_NAME_UPPER=

# ── Optional ─────────────────────────────────────────────────────────────

# v4 "Read Access Token" (JWT) from
# https://www.themoviedb.org/settings/api → "API Read Access Token".
# Enables trailer autoplay in the modal hero and home hero. Trailers are
# silently disabled if this is empty.
TMDB_READ_TOKEN=

# Human-readable product/device name shown on plex.tv when users link.
# Defaults to "ChimpFlix" if unset.
PLEX_PRODUCT_NAME=ChimpFlix
PLEX_DEVICE_NAME=ChimpFlix

# Legacy single-server fallback URL. ZacFlix is now multi-tenant: when a
# user signs in, the app calls plex.tv to list every server their account
# has access to and shows a picker. The selected server's URL is stored
# in a session cookie.
#
# This env var is only used to keep older sessions (created before the
# multi-tenant upgrade) alive — they get pinned to this URL until the
# user signs out and back in. New deployments can leave this blank.
PLEX_SERVER_URL=

# ── Security (recommended for any deployment beyond plain-HTTP LAN) ──────

# Canonical user-facing origin. When set, ZacFlix uses it as the
# authoritative source for redirect targets (Plex OAuth callback,
# post-logout) and the Secure cookie flag. Without it the app falls back
# to the Host header — fine for a LAN homelab over HTTP, but in any
# Internet-facing deployment set this so attacker-controlled Host
# headers can't redirect users to arbitrary sites.
#
# Example: APP_PUBLIC_ORIGIN=https://chimpflix.example.com
APP_PUBLIC_ORIGIN=

# Opt-in: trust X-Forwarded-Proto from the reverse proxy when
# APP_PUBLIC_ORIGIN is not set. Set to "1" if you terminate TLS at
# Traefik/nginx/Caddy and want the Secure cookie flag honored on
# https requests. Leave unset for plain HTTP.
APP_TRUST_PROXY=

# ── Docker only ──────────────────────────────────────────────────────────

# Directory where the boot-time bootstrap auth file is persisted. The
# docker-compose mount maps a host directory to /app/state. Without this
# (or with an empty value) the bootstrap is ephemeral and every restart
# pays a cold-start cost. The file holds a per-server access token —
# lock the host directory down accordingly.
APP_STATE_DIR=
